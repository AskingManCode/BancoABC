@page
@model Interfaz_Adm_Usr.Pages.IndexModel
@{
    ViewData["Title"] = "Login";
}

<div class="login-container">
    <h2>Inicio de Sesión</h2>

    <form method="post">
        <div class="form-group">
            <label>Usuario</label>
            <input asp-for="Usuario.User" class="form-control" placeholder="Usuario" required />
        </div>

        <div class="form-group">
            <label>Contraseña</label>
            <input asp-for="Usuario.Password" type="password" class="form-control" placeholder="Contraseña" required />
        </div>

        <button type="submit" class="btn-login">Ingresar</button>
    </form>

    @if (!string.IsNullOrEmpty(Model.MensajeError))
    {
        <div class="error-msg">
            @Model.MensajeError
        </div>
    }
</div>